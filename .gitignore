/target
*.o
*.wasm

# binários compilados pelos exemplos — mantém os fontes .lex versionados
/examples/*
!/examples/*.lex
!/examples/*/
/hello

# pacotes baixados pelo gerenciador (lex install) — o lex.lock é versionado
/lex_modules
**/lex_modules

# extensão VS Code: dependências e bundle são gerados (build no vscode:prepublish)
/editors/vscode-lex/node_modules
/editors/vscode-lex/out

# settings locais do Claude (por máquina)
/.claude/settings.local.json

# dados do registry-site (pacotes publicados em runtime) e o binário compilado
/registry-site/data
/registry

# binário do compilador (gerado por ./selfhost/build-seed.sh)
bin/

.DS_Store
