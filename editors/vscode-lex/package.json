{
  "name": "lex-lang",
  "displayName": "lex language",
  "description": "Syntax highlighting + diagnósticos ao vivo (LSP) para a linguagem lex (TypeScript-like, compilada para LLVM)",
  "version": "0.1.0",
  "publisher": "lex",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:lex"
  ],
  "contributes": {
    "languages": [
      {
        "id": "lex",
        "aliases": [
          "lex",
          "Lex"
        ],
        "extensions": [
          ".lex"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "lex",
        "scopeName": "source.lex",
        "path": "./syntaxes/lex.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "lex.restartServer",
        "title": "lex: Reiniciar o Language Server"
      }
    ],
    "configuration": {
      "title": "lex",
      "properties": {
        "lex.server.path": {
          "type": "string",
          "default": "",
          "markdownDescription": "Caminho do binário do compilador `lex` usado como Language Server (`lex lsp`). Se vazio, a extensão procura `target/release/lex` e depois `target/debug/lex` na raiz do workspace. **Não** usa o `lex` do PATH por padrão (em sistemas Unix `/usr/bin/lex` costuma ser o flex)."
        },
        "lex.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Loga a comunicação entre o editor e o `lex lsp` no canal de saída (para depurar o LSP)."
        }
      }
    }
  },
  "scripts": {
    "compile": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node",
    "watch": "npm run compile -- --sourcemap --watch",
    "vscode:prepublish": "npm run compile -- --minify"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.75.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.4.0"
  }
}
